  23          /** 
  24           * @brief        TSD初始化函数
  25           * @param        None
  26           * @return       none
  27           * @date         2022-09-13
  28           * @version      1.0   
  29           * @property     Public
  30          */
  31          void TSD_Init(void)
  32          {    
  33   1        TSDIE     =1;                 //温度保护中断使能
  34   1        SetBit(TSD_CR , TSDEN);       //温度保护使能
  35   1       
  36   1        SetBit(IP0 , PLVW1);          //中断优先级设置
  37   1        SetBit(IP0 , PLVW0);   
  38   1          
  39   1        SetBit(TSD_CR , TSDADJ3);     //温度保护值设定
  40   1        SetBit(TSD_CR , TSDADJ2);
  41   1        SetBit(TSD_CR , TSDADJ1);
  42   1        ClrBit(TSD_CR , TSDADJ0);
  43   1        
  44   1        SetBit(TSD_CR , TSEN_EN);       //温度传感器使能 
  45   1      }
  46          
