  11          #include <CRC.h>
  12          
  13          
  14          /****************************************************************************
  15          CRC16_CCITT_FALSE 硬件实现
  16          ****************************************************************************/
  17          unsigned short CRC_Check(unsigned char start_sector , unsigned char offset_sector)
  18          {
  19   1          unsigned short crcresult = 0x0000;
  20   1      
  21   1          unsigned short tempH = 0x00;
  22   1          unsigned short tempL = 0x00;
  23   1      
  24   1          SetBit(CRC_CR , CRCVAL);    //0-->0x0000  1-->0xffff
  25   1          SetBit(CRC_CR , CRCDINI);   //1-->init success
  26   1      
  27   1          CRC_BEG = start_sector;     //起始扇区
  28   1          CRC_CNT = offset_sector;  //扇区偏移量 0-->1个扇区
  29   1      
  30   1          //1个空扇区-->0x41E8   2个空扇区-->0x1634
  31   1          //1个0xFF  -->0x5B2F  0x00~0xFF-->0x3FBD
  32   1          SetBit(CRC_CR , AUTOINT);   //自动计算使能
  33   1          /***************************************************/
  34   1      
  35   1          SetBit(CRC_CR , CRCPNT);  
  36   1          tempH = CRC_DR;
  37   1          ClrBit(CRC_CR , CRCPNT);  
  38   1          tempL = CRC_DR;
  39   1          crcresult = (unsigned short)(tempH << 8) + tempL;
  40   1          return crcresult;
  41   1      }


