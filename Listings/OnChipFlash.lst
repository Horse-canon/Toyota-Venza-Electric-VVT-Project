  12          uint8 Flash_Sector_Erase(uint8 xdata *FlashAddress)
  13          {
  14   1          bool TempEA;
  15   1      
  16   1          TempEA = EA;
  17   1          EA = 0;                            //Flash自擦除前先关总中断
  18   1      
  19   1          if(FlashAddress < 0x7F00)          // 不擦除最后一个扇区,0X7F00~0X7FFF
  20   1          {
  21   2              FLA_CR = 0x03;                 //使能自擦除
  22   2              FLA_KEY = 0x5a;
  23   2              FLA_KEY = 0x1f;                //flash预编程解锁
  24   2              _nop_();
  25   2              *FlashAddress = 0xff;          //写任意数据
