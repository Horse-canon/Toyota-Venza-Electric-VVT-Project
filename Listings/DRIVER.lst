  18          /** 
  19           * @brief        Derier输出配置初始化
  20           * @date         2022-09-13
  21           */
  22          void Driver_Init(void)
  23          {
  24   1          DRV_ARR = PWM_VALUE_LOAD ;      // 载波频率的周期值
  25   1          DRV_DTR = PWM_LOAD_DEADTIME;  // 死区时间
  26   1          DRV_DR  = 0;
  27   1          DRV_CMR = 0x0ABF;               // UH/VH/WH UL/VL/WL 互补
  28   1          DRV_OUT = 0x00;                 // 空闲电平，默认高电平有效
  29   1      
  30   1        /*驱动有效电平和空闲电平*/
  31   1        #if (PWM_LEVEL_MODE == HIGH_LEVEL)
  32   1        {
  33   2              ClrBit(PI_CR , HINV);      // 反相关闭
  34   2              ClrBit(PI_CR , LINV);      // 反相关闭
  35   2        }
  36   1        #elif (PWM_LEVEL_MODE == LOW_LEVEL)
                {
                      SetBit(PI_CR , HINV);  // 反相打开
                      SetBit(PI_CR , LINV);  // 反相打开
                }
                #elif (PWM_LEVEL_MODE == UP_H_DOWN_L)
                {
                      ClrBit(PI_CR , HINV);  // 反相关闭
                      SetBit(PI_CR , LINV);  // 反相打开
                }
                #elif (PWM_LEVEL_MODE == UP_L_DOWN_H)
                {
                      SetBit(PI_CR , HINV);  // 反相打开
                      ClrBit(PI_CR , LINV);  // 反相关闭
                }
                #endif //end PWM_Level_Mode   
  52   1              
  53   1          ClrBit(DRV_SR , FGIE);  //FG中断使能      0-->Disable   1-->Enable
C51 COMPILER V9.57.0.0   DRIVER                                                            06/29/2026 21:31:46 PAGE 2   

  54   1      
  55   1          /*清中断标志位，使能中断，配置比较值，设置中断优先级*/
  56   1          ClrBit(DRV_SR , DCIF);  //清除DRV中断标志位
  57   1          /**************************************************
  58   1          DRV比较匹配中断模式
  59   1          当计数值等于DRV_COMR时，根据DCIM的设置判断是否产生中断标记
  60   1          00：不产生中断        01：上升方向
  61   1          10：下降方向          11：上升/下降方向
  62   1          *************************************************/
  63   1          SetBit(DRV_SR , DCIM1);
  64   1          ClrBit(DRV_SR , DCIM0);
  65   1      
  66   1          /*设置DRV计数器的比较匹配值，当DRV计数值与COMR相等时，根据DRV_SR寄存器的DCI
             -M是否产生比较匹配事件*/
  67   1          DRV_COMR = (PWM_VALUE_LOAD >> 3);
  68   1      
  69   1          SetBit(IP0, PDRV1);  //中断优先级设置为1，优先级低于FO硬件过流
  70   1          ClrBit(IP0, PDRV0);
  71   1          ClrBit(DRV_SR , DCIP);  //0-->1个计数周期产生中断  1-->2个计数周期产生中断
  72   1      
  73   1          ClrBit(DRV_CR , FOCEN);
  74   1          /*MESEL为0，ME模块工作在BLDC模式
  75   1          MESEL为1，ME模块工作在FOC/SVPWM/SPWM模式*/
  76   1          SetBit(DRV_CR , MESEL);
  77   1      
  78   1          SetBit(DRV_CR , DRVEN); // 计数器使能    0-->Disable 1-->Enable
  79   1          ClrBit(DRV_CR , DRPE);  // 计数器比较值预装载使能 0-->Disable            1-->Enable
  80   1          SetBit(DRV_CR , DRVOE); // Driver输出使能0-->Disable    1-->Enable
  81   1      
  82   1              SetBit(CCFG2, VBB_VSEL);  //VBB_LDO设置 0：10V 1：12V
  83   1              ClrBit(CCFG1, VBB_DIS);  //VBB_LDO使能输出后需要延时等待1ms以上
  84   1      }


