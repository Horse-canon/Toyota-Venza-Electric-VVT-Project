 171   1        ClrBit(TIM3_CR0 , T3PSC0);  //100-->1.5M  101-->750K    110-->375K  111-->输入时为：48M
 172   1        
 173   1          ClrBit(TIM3_CR0 , T3OCM);
 174   1        ClrBit(TIM3_CR0 , T3IRE); //比较匹配中断/脉宽检测中断0-->Disable  1-->Enable
 175   1        ClrBit(TIM3_CR0 , T3OPM); //0-->计数器不停止    1-->单次模式  
 176   1        
 177   1        SetBit(TIM3_CR1 , T3IPE); //输入Timer PWM周期检测中断使能 0-->Disable  1-->Enable
C51 COMPILER V9.57.0.0   TIMER                                                             06/22/2026 16:14:00 PAGE 4   

 178   1        SetBit(TIM3_CR1 , T3IFE); //计数器上溢中断使能 0-->Disable  1-->Enable
 179   1        ClrBit(TIM3_CR1 , T3NM1); //输入噪声脉宽选择
 180   1        ClrBit(TIM3_CR1 , T3NM0); //00-->不滤波  01-->4cycles    10-->8cycles  11-->16cycles
 181   1        
 182   1      //  TIM3__DR = 1200;
 183   1      //  TIM3__ARR = 2400;
 184   1          ClrBit(TIM3_CR0 , T3MOD);   //0-->Timer模式       1-->输出模式
 185   1          SetBit(TIM3_CR1 , T3EN);    //TIM3使能    0-->Disable  1-->Enable
 186   1      }
