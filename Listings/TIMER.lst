  23              /*---------------------------------------------------------------------------*/
  24          /* TIM1捕获中断定时器 */
  25          void TIM1_HALL_Init(void)
  26          {
  27   1          /* 禁用定时器 */
  28   1          ClrBit(TIM1_CR0, T1BCEN);
  29   1      
  30   1          /* 定时器分频 */
  31   1          SetReg(TIM1_CR3, T1PSC2 | T1PSC1 | T1PSC0, T1PSC2 |T1PSC1| T1PSC0);
  32   1          
  33   1        
  34   1          /* 基本定时器计数值及重载值 */
  35   1          TIM1__BARR  = TIM1_VALUE_LOAD;
  36   1          TIM1__BCNTR = 0;
  37   1      
  38   1          //CMP_CR4  FAEN 使能后，TIM1_CR3 的 T1INM 和 CMP_SAMR 的参数均扩大 4 倍
  39   1          //SetBit(CMP_CR4, FAEN);
  40   1          
  41   1        
  42   1        
  43   1          /* 输入源选择 */
  44   1          ClrBit(TIM1_CR3, T1TIS1);
  45   1          ClrBit(TIM1_CR3, T1TIS0);
  46   1          ClrBit(HALL_CR, HALLSEL);
  47   1          
  48   1            /* HALL输入滤波 */
  49   1          SetReg(TIM1_CR3, T1INM1 | T1INM0, T1INM1 | T1INM0);  // 96x41.67ns = 4us滤波时长。
  50   1        
  51   1          /* 触发极性 */
  52   1          SetBit(TIM1_DBR7, T1CPE2 | T1CPE1 | T1CPE0); // 三相双跳变沿
  53   1          
C51 COMPILER V9.57.0.0   TIMER                                                             06/22/2026 16:14:00 PAGE 2   

  54   1          TIM1_CR4 = 7;
  55   1            
  56   1          /* 设置事件复位源 */
  57   1          SetBit(TIM1_CR2, T1BRS);  // 位置检测复位
  58   1          TIM1_SR &= 0x00;
  59   1          ClrBit(TIM1_IER, T1ADIE);   // 禁止TIM1 AD检测中断   
  60   1          ClrBit(TIM1_IER, T1ROIE);   // 禁止TIM1重载定时器上溢中断
  61   1          ClrBit(TIM1_IER, T1WTIE);   // 禁止写入时序中断
  62   1              
  63   1          /* 开启位置检测中断 */
  64   1          SetBit(TIM1_IER, T1PDIE);  
  65   1       
  66   1          /*  开定时器上溢中断 */
  67   1          SetBit(TIM1_IER, T1BOIE);
  68   1          
  69   1          SetReg(IP1, PTIM10 | PTIM11, PTIM11|PTIM10);
  70   1          
  71   1          /* 使能定时器 */
  72   1          SetBit(TIM1_CR0, T1BCEN);
  73   1          ClrBit(IP1, PTIM11); /*中断优先级*/
  74   1          SetBit(IP1, PTIM10); /*中断优先级*/    
  75   1        
  76   1          /* 清除中断标志位 - 初始化 */
  77   1          ClrBit(TIM1_SR, T1BOIF | T1ROIF | T1WTIF | T1PDIF | T1BDIF);
  78   1          
  79   1      
  80   1      }
