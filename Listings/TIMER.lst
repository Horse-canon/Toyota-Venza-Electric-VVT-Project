 110          /*  -------------------------------------------------------------------------------------------------
 111              Function Name  : Time2_Hall_Init
 112              Description    : Hall翻转计时
 113              Date           : 2022-06-03
 114              Parameter      : None
 115              ------------------------------------------------------------------------------------------------- */
C51 COMPILER V9.57.0.0   TIMER                                                             06/22/2026 16:14:00 PAGE 3   

 116          void Time2_Hall_Init(void)
 117          {
 118   1        /*-------------------------------------------------------------------------------------------------
 119   1          先停止计数，配置完寄存器后，最后启动计数
 120   1          -------------------------------------------------------------------------------------------------*/
 121   1          ClrBit(TIM2_CR1, T2CEN); // 0，停止计数；1,使能计数
 122   1          /*-------------------------------------------------------------------------------------------------
 123   1          时钟分频设置(T2PSC)
 124   1          000:cpuclk(24MHz)         001:cpuclk/2^1(12MHz)   010:cpuclk/2^2(6MHz)    011:cpuclk/2^3(3MHz)
 125   1          100:cpuclk/2^4(1.5MHz)    101:cpuclk/2^5(750KHz)  110:cpuclk/2^6(375KHz)  111:cpuclk/2^7(187.5KHz)
 126   1          -------------------------------------------------------------------------------------------------*/
 127   1          SetReg(TIM2_CR0, T2PSC0 | T2PSC1 | T2PSC2, T2PSC0 | T2PSC1 | T2PSC2);
 128   1          /*-------------------------------------------------------------------------------------------------
 129   1          /模式选择
 130   1          T2MODE1，T2MODE0
 131   1          00--输入Timer模式；01--输出模式
 132   1          10--输入Count模式；11--QEP或者ISD模式
 133   1          -------------------------------------------------------------------------------------------------*/
 134   1          SetReg(TIM2_CR0, T2MOD0 | T2MOD1, T2MOD0);
 135   1          /*-------------------------------------------------------------------------------------------------
 136   1          清除中断标志位
 137   1          禁止PWM周期检测中断使能
 138   1          -------------------------------------------------------------------------------------------------*/
 139   1          ClrBit(TIM2_CR0, T2CES);                                // 清零脉冲计数器不使能
 140   1          ClrBit(TIM2_CR1, T2IR | T2IF | T2IP);                   // 清零中断标志位
 141   1          SetBit(TIM2_CR1, T2IFE);
 142   1          SetBit(IP1, PTIM21); /*中断优先级*/
 143   1          ClrBit(IP1, PTIM20); /*中断优先级*/                                  
 144   1          /*-------------------------------------------------------------------------------------------------
 145   1          配置周期值、比较值、计数值
 146   1          禁止PWM周期检测中断使能
 147   1          使能计数器上溢中断使能
 148   1          -------------------------------------------------------------------------------------------------*/
 149   1          TIM2__ARR  = TIM2_VALUE_LOAD;                                    // TIM2 Period = 0.32s
 150   1          TIM2__DR   = 20000;
 151   1          TIM2__CNTR = 0;
 152   1          /*-----------启动计数------------------------------------------------*/
 153   1          SetBit(TIM2_CR1, T2CEN);                                 //启动计数
 154   1      }
