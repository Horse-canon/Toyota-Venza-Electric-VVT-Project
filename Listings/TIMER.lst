  83          /** 
  84           * @brief        Timer2初始化
  85           * @date         2022-09-13
  86           */
  87          void Timer2_Init(void)
  88          {
  89   1        SetBit(PH_SEL , T2SEL);     //P10
  90   1        SetBit(PH_SEL , T2SSEL);  //P07 
  91   1        ClrBit(TIM2_CR0 , T2PSC2);  //计数器时钟分频选择
  92   1        ClrBit(TIM2_CR0 , T2PSC1);  //000-->24M   001-->12M   010-->6M  011-->3M
  93   1        ClrBit(TIM2_CR0 , T2PSC0);  //100-->1.5M  101-->750K    110-->375K  111-->187.5K
  94   1        ClrBit(TIM2_CR0 , T2OCM);
  95   1        SetBit(TIM2_CR0 , T2IRE); //比较匹配中断/脉宽检测中断0-->Disable  1-->Enable
  96   1        ClrBit(TIM2_CR0 , T2CES); 
  97   1        
  98   1        ClrBit(TIM2_CR1 , T2IPE); //输入Timer PWM周期检测中断使能 0-->Disable  1-->Enable
  99   1        ClrBit(TIM2_CR1 , T2IFE); //计数器上溢中断使能 0-->Disable  1-->Enable
 100   1        ClrBit(TIM2_CR1 , T2FE);  //输入噪声滤波使能，小于4个时钟周期脉宽滤除
 101   1        ClrBit(TIM2_CR1 , T2DIR); //QEP&ISD&步进模式专用：当前的方向 0-->正向 1-->反向  
 102   1        
 103   1        TIM2__DR = 1200;
 104   1        TIM2__ARR = 2400;
 105   1          ClrBit(TIM2_CR0 , T2MOD1);  //00-->输入Timer模式        01-->输出模式
 106   1        SetBit(TIM2_CR0 , T2MOD0);  //10-->输入Counter模式      11-->QEP&ISD&步进模式
 107   1          SetBit(TIM2_CR1 , T2CEN); //TIM2使能  0-->Disable  1-->Enable
 108   1      }
