 297          /*  -------------------------------------------------------------------------------------------------
 298              Function Name  : Fault_Detection
 299              Description    : 故障检测与保护,扫描周期默认为1ms
 300                               所有故障发送只进行 故障码 赋值
 301                               禁止在状态机以外地方进行状态跳转
 302              Date           : 2022-07-01
 303              Parameter      : None
 304              ------------------------------------------------------------------------------------------------- */
 305          void Fault_Detection(void)
 306          {
 307   1          #if (OverTPProtectEn == 1)
                  {
                      Fault_Temperature();
                  }
                  #endif
 312   1          #if (VoltageProtectEn == 1)
                  {
                      Fault_Voltage();
                  }
                  #endif
 317   1          #if (StallProtectEn == 1)
                  {
                      Fault_Stall();
                  }
                  #endif
 322   1          #if (PhaseLossProtectEn == 1)
                  {
                      Fault_PhaseLoss();
                  }
                  #endif
 327   1          Fault_Recovery();
 328   1      }
