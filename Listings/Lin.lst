 576          /*  -------------------------------------------------------------------------------------------------
 577              Function Name  : ReceiveSYS
 578              Description    : 总线接收数据处理
 579              Date           :
 580                             : [输入]
 581              ------------------------------------------------------------------------------------------------- */
 582          uint16 err = 0;
 583          uint16 LinReceiveLen = 0;
 584          void ReceiveSYS(uint8 PID)
 585          {
 586   1          uint8 i = 0;
 587   1          LinReceiveLen = LIN_SIZE;
 588   1          switch (PID)
 589   1          {
 590   2              case 0x10://DR_MSM_MotorCtlMsg
 591   2                  #if (MotorMode == DR_RearVertical)
                          {
