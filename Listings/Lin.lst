  20          /**
  21          * @brief     Lin初始化
  22          * @date      2022-08-13
  23          */
  24          void LIN_Init(void)
  25          {
  26   1          DMA0_BA  = 0;//带有Boot的先清零再赋值
  27   1          DMA0_CR0 = 0;
  28   1          LIN_CR = 0;
  29   1          /*-------------------------------------------------------------------------------------------------
  30   1           DMA通道配置
  31   1           DMASEL=1:配置为DMA1  DMASEL=0:配置为DMA0  从 UART2 到 XRAM
  32   1          -------------------------------------------------------------------------------------------------*/
  33   1          SetBit(DMA0_CR0, DMAEN | DMACFG2 | DMACFG1);
  34   1          ClrBit(LIN_CR, DMASEL);
  35   1          DMA0_BA = ucaLinBuff; /* 使用dma0，spi使用dma1 */
  36   1          /*-------------------------------------------------------------------------------------------------
  37   1          LIN通道配置
  38   1          00:配置为TXD：P00 RXD：p01;    ！！！！！6816的demo连接的时P36,37 需要飞线
  39   1          10:配置为TXD：P10 RXD：p11;
  40   1          11:单线lin P11
  41   1          注意：6806的P10P11没有内部上拉，端口转移时，P10需配置外部上拉
  42   1          注意：6806的P10P11没有内部上拉，端口转移时，P10需配置外部上拉
  43   1          注意：6806的P10P11没有内部上拉，端口转移时，P10需配置外部上拉
  44   1          ------------------------------------------------------------------------------------------------*/
  45   1      //    SetBit(LIN_CR, CHSEL1); /* 端口转移 */
  46   1      //    ClrBit(LIN_CR, CHSEL0); /* 端口转移 */
  47   1      //    ClrBit(P1_PU, P11HV_EN); /* 端口转移 */
  48   1          SetBit(P1_PU, P10HV_EN); /* 端口转移 */
  49   1          SetBit(LIN_CR, CHSEL1); /* 端口转移 */
  50   1          SetBit(LIN_CR, CHSEL0); /* 端口转移 *
  51   1          SetBit(IP3, PSPI_UT21);
  52   1          ClrBit(IP3, PSPI_UT20);
  53   1          ClrBit(LIN_CR, AUTOSIZE); /* 自动长度设定（ID[4][5]决定） */
C51 COMPILER V9.57.0.0   LIN                                                               06/29/2026 21:31:46 PAGE 2   

  54   1          //LIN_BAUD = 0x04E1;
  55   1          SetBit(LIN_CR, LINIE);    /* 中断设置 */
  56   1          SetBit(LIN_CSR, LINEN);   /* LIN模块使能 */
  57   1      }
